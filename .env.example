# Copy to .env (never commit .env)

AIRTABLE_TOKEN=pat_xxxxxxxxxxxxxxxx

# LLM: gemini | anthropic | ollama | local (local = free heuristics, no API)
# LLM_PROVIDER=gemini
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxx
# Optional: default gemini-2.0-flash
# GEMINI_MODEL=gemini-2.5-flash

# Claude (when LLM_PROVIDER=anthropic) — https://console.anthropic.com/
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxx
# Optional: default claude-3-5-haiku-20241022 (cheaper); or claude-sonnet-4-20250514 etc.
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# Free local Ollama (https://ollama.com) — after `ollama pull llama3.2`
# LLM_PROVIDER=ollama
# OLLAMA_MODEL=llama3.2
# OLLAMA_BASE_URL=http://127.0.0.1:11434
